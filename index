.adj-slider::-webkit-slider-thumb:active{transform:scale(1.2)}
.adj-marks{display:flex;justify-content:space-between;margin-top:7px}
.adj-marks span{font-size:.62rem;color:var(--mid)}
.adj-tip{margin-top:12px;font-size:.78rem;color:#888;line-height:1.6}
.adj-notice{margin-top:10px;background:#fff;border-radius:10px;padding:11px 13px;font-size:.78rem;color:#666;line-height:1.6;border-left:3px solid var(--p1)}
.btot{border-radius:14px;padding:15px;display:flex;justify-content:space-between;align-items:center;margin-top:14px;background:linear-gradient(135deg,var(--p1),var(--p4))}
