.rt{font-family:'Jua',cursive;font-size:1.9rem;color:#fff;line-height:1.2;position:relative;z-index:1;text-shadow:0 2px 12px rgba(0,0,0,.15)}
.rs{color:rgba(255,255,255,.8);font-size:.84rem;margin-top:8px;position:relative;z-index:1}
.rm{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:16px;position:relative;z-index:1}
.rc{background:rgba(255,255,255,.25);color:#fff;font-size:.72rem;font-weight:700;padding:5px 13px;border-radius:99px}
.rw{width:100%;overflow:hidden;line-height:0}
.rw svg{display:block;width:100%;height:32px}
.rb{padding:0 16px}
.sh{font-family:'Jua',cursive;font-size:1.15rem;margin:26px 0 14px;display:flex;align-items:center;gap:8px}
.sn{width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.72rem;color:#fff;font-weight:700;flex-shrink:0}
/* 타임라인 */
.tl{display:flex;flex-direction:column;gap:12px}
.ti{background:var(--card);border-radius:18px;padding:18px 18px 18px 20px;border:1.5px solid var(--border);box-shadow:3px 4px 0 #f0e0e8;display:flex;gap:14px;animation:slr .45s ease both}
.ti:nth-child(1){animation-delay:.06s}.ti:nth-child(2){animation-delay:.14s}.ti:nth-child(3){animation-delay:.22s}.ti:nth-child(4){animation-delay:.30s}.ti:nth-child(5){animation-delay:.38s}.ti:nth-child(6){animation-delay:.44s}
