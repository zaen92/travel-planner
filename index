.nb:disabled{opacity:.3;cursor:not-allowed;transform:none;box-shadow:none}
/* 결과 */
#R{padding-bottom:80px}
.rh{padding:52px 24px 50px;text-align:center;position:relative;overflow:hidden}
.rh::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(255,255,255,.15),transparent 60%)}
.re{font-size:3.6rem;display:block;margin-bottom:12px;animation:bop .6s cubic-bezier(.34,1.56,.64,1);position:relative;z-index:1}
