.bc{background:var(--card);border-radius:18px;padding:20px;border:1.5px solid var(--border);box-shadow:3px 4px 0 #f0e0e8;margin-bottom:12px}
.bgr{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.brow{background:var(--bg);border-radius:12px;padding:12px;display:flex;flex-direction:column;gap:4px}
.bl{font-size:.7rem;color:var(--mid)}.bv{font-family:'Jua',cursive;font-size:1.05rem}
.adj{background:linear-gradient(135deg,#ffeef5 0%,#e8f4ff 100%);border-radius:16px;padding:18px;border:1.5px solid #fcd5e0}
