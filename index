          // 해당 동네 가능한 스타일 목록
          var vs = [];
          for (var i = 0; i < COURSES.length; i++) {
            var c = COURSES[i];
            if (c.city === ans.city && c.district === d && vs.indexOf(c.vibe) === -1) {
              vs.push(c.vibe);
            }
          }
          return {e: "📌", t: d, s: vs.join(" · ")};
        })
      });
    } else if (dlist.length === 1) {
      // 동네 1개면 자동 선택 (스텝 안 보임)
      ans.district = dlist[0];
    }
  }

  // STEP 2: 여행 스타일 (도시+동네 선택된 경우)
  if (ans.city) {
    var district = ans.district || (CITY_META[ans.city] ? CITY_META[ans.city].districts[0] : null);
    var availVibes = [];
    if (district) {
      for (var i = 0; i < COURSES.length; i++) {
        var c = COURSES[i];
        if (c.city === ans.city && c.district === district && availVibes.indexOf(c.vibe) === -1) {
          availVibes.push(c.vibe);
        }
      }
    }
    // 없으면 전체 보여줌
    if (availVibes.length === 0) availVibes = ["맛집","자연","문화"];
    steps.push({
      id: "vibe",
      ch: "🎯 스타일", cc: "#ffd166",
      q:  "어떤 여행을 원하시나요?",
      opts: availVibes.map(function(v) {
        return {e: VIBE_META[v].e, t: v, s: VIBE_META[v].s};
      })
    });
  }

  // STEP 3: 동행 (스타일 선택된 경우)
  if (ans.vibe || ans.city) {
    steps.push({
      id: "who",
      ch: "👥 동행", cc: "#caffbf",
      q:  "누구랑 함께 가세요?",
      opts: WHO_META
    });
  }

  // STEP 4: 예산 (항상 마지막)
  if (ans.who || ans.city) {
    steps.push({id: "budget", ch: "💰 예산", cc: "#ffb3c6", q: "하루 예산을 설정해주세요 (1인)"});
  }
}

// ── dots 렌더링 ────────────────────────────────────
function renderDots() {
  var total = steps.length;
  var html  = "";
  for (var i = 0; i < total; i++) {
    var cls = "dot";
    if (i === step) cls += " on";
    else if (i < step) cls += " dn";
    html += '<div class="' + cls + '"></div>';
  }
  document.getElementById("DT").innerHTML = html;
}

// ── 스텝 렌더링 ───────────────────────────────────
function render(s) {
  step = s;
  rebuildSteps();       // 항상 최신 ans 기준으로 스텝 재계산
  renderDots();

  // step이 steps 범위를 벗어나면 처음으로
  if (step >= steps.length) { step = 0; }
  var q = steps[step];
  if (!q) { step = 0; q = steps[0]; }

  var isLast = (step === steps.length - 1);
  var cc = q.cc;
  var h  = '<div class="qchip" style="background:' + cc + '33;color:' + cc + '">' + q.ch + '</div>'
          + '<h2>' + q.q + '</h2>';

  if (q.id !== "budget") {
    // 옵션 버튼 목록
    var isCityStep = (q.id === "city");
    h += '<div class="olist' + (isCityStep ? " grid2" : "") + '" id="OL">';
    var opts = q.opts || [];
    for (var i = 0; i < opts.length; i++) {
      var o   = opts[i];
      var sel = (ans[q.id] === o.t);
      var bs  = sel ? "border-color:" + cc + ";background:" + cc + "22" : "";
      var cs  = sel ? "background:" + cc + ";border-color:" + cc : "";
      h += '<button class="ob' + (sel ? " sel" : "") + '" style="' + bs + '" data-idx="' + i + '">'
         + '<span class="oi">' + o.e + '</span>'
         + '<span class="ot">' + o.t + (o.s ? '<span class="os">' + o.s + '</span>' : '') + '</span>'
         + '<span class="oc" style="' + cs + '">' + (sel ? "&#10003;" : "") + '</span>'
         + '</button>';
    }
    h += '</div>';
    h += '<button class="nb" id="NB" ' + (ans[q.id] ? "" : "disabled") + '>'
       + (isLast ? "✈ 코스 찾기!" : "다음으로 →") + '</button>';
  } else {
    // 예산 슬라이더
    var ci = ans.budget !== undefined ? ans.budget : 2;
    var tl = ["절약 (기본 스팟만)", "알뜰 (기본 스팟만)", "추천 (선택 스팟 1개↑)", "여유 (선택 스팟 2개↑)", "프리미엄 (모든 스팟)", "프리미엄 (모든 스팟)", "프리미엄 (모든 스팟)"];
    h += '<div class="sb">'
       + '<div class="sd">'
       + '<div class="sv" id="SV">' + BL[ci] + '만원</div>'
       + '<div class="su" id="STIER">' + tl[ci] + '</div>'
       + '</div>'
       + '<div class="st"><span class="sl">2만</span>'
       + '<input type="range" min="0" max="6" value="' + ci + '" oninput="onBudgetSlide(this.value)">'
       + '<span class="sl">20만+</span></div>'
       + '<div class="sm">' + BL.map(function(v){return"<span>"+v+"</span>";}).join("") + '</div>'
       + '<div style="margin-top:14px;background:#fff0f5;border-radius:12px;padding:11px 14px;font-size:.79rem;color:#c06080;line-height:1.6;border-left:3px solid #ff8fab">'
       + '💡 예산이 높을수록 스팟이 자동으로 추가돼요!</div>'
       + '</div>';
    h += '<button class="nb" id="NB">✈ 코스 찾기!</button>';
  }

  document.getElementById("CA").innerHTML = '<div class="qb">' + h + '</div>';

  // ── 이벤트: 옵션 버튼 클릭 ──
  var ol = document.getElementById("OL");
  if (ol) {
    ol.addEventListener("click", function(ev) {
      var btn = ev.target.closest(".ob");
      if (!btn) return;
      var idx = parseInt(btn.getAttribute("data-idx"), 10);
      var o2  = steps[step].opts[idx];
      var qid = steps[step].id;

      // 상위 선택이 바뀌면 하위 초기화
      if (qid === "city")     { ans = {city: o2.t}; }
      else if (qid === "district") { ans.district = o2.t; delete ans.vibe; delete ans.who; delete ans.budget; }
      else if (qid === "vibe")     { ans.vibe = o2.t; delete ans.who; delete ans.budget; }
      else                        { ans[qid] = o2.t; }

      // rebuildSteps 후 같은 스텝 다시 렌더(선택 표시)
      rebuildSteps();
      renderDots();

      // 시각 업데이트 (버튼 선택 표시)
      ol.querySelectorAll(".ob").forEach(function(b) {
        b.classList.remove("sel");
        b.style.borderColor = ""; b.style.background = "";
        var ck = b.querySelector(".oc");
        ck.style.background = ""; ck.style.borderColor = ""; ck.innerHTML = "";
      });
      btn.classList.add("sel");
      btn.style.borderColor = steps[step].cc;
      btn.style.background  = steps[step].cc + "22";
      var ck2 = btn.querySelector(".oc");
      ck2.style.background  = steps[step].cc;
      ck2.style.borderColor = steps[step].cc;
      ck2.innerHTML = "&#10003;";

      document.getElementById("NB").disabled = false;
    });
  }

  // ── 이벤트: 다음 버튼 ──
  document.getElementById("NB").addEventListener("click", function() {
    rebuildSteps();
    if (step < steps.length - 1) {
      render(step + 1);
    } else {
      find();
    }
  });
}

function onBudgetSlide(val) {
  var i  = parseInt(val, 10);
  ans.budget = i;
  document.getElementById("SV").textContent = BL[i] + "만원";
  var tl = ["절약 (기본 스팟만)","알뜰 (기본 스팟만)","추천 (선택 스팟 1개↑)","여유 (선택 스팟 2개↑)","프리미엄 (모든 스팟)","프리미엄 (모든 스팟)","프리미엄 (모든 스팟)"];
  document.getElementById("STIER").textContent = tl[i];
}

// ── 예산 티어 계산 ────────────────────────────────
function getTier(bi) {
  if (bi <= 1) return 0;
  if (bi <= 3) return 1;
  if (bi <= 5) return 2;
  return 3;
}

// ── 코스 찾기 ─────────────────────────────────────
function find() {
  var city     = ans.city;
  var district = ans.district || (CITY_META[city] ? CITY_META[city].districts[0] : null);
  var vibe     = ans.vibe;
  var who      = ans.who;
  var bi       = ans.budget !== undefined ? ans.budget : 2;
  var bv       = BL[bi];

  var course = null;

  // 1. 완전 일치
  for (var i = 0; i < COURSES.length; i++) {
    var c = COURSES[i];
    if (c.city===city && c.district===district && c.vibe===vibe && c.who===who) { course=c; break; }
  }
  // 2. who 폴백
  if (!course) for (var i = 0; i < COURSES.length; i++) {
    var c = COURSES[i];
    if (c.city===city && c.district===district && c.vibe===vibe) { course=c; break; }
  }
  // 3. district 폴백
  if (!course) for (var i = 0; i < COURSES.length; i++) {
    var c = COURSES[i];
    if (c.city===city && c.vibe===vibe && c.who===who) { course=c; break; }
  }
  // 4. city+vibe
  if (!course) for (var i = 0; i < COURSES.length; i++) {
    var c = COURSES[i];
    if (c.city===city && c.vibe===vibe) { course=c; break; }
  }
  // 5. city만
  if (!course) for (var i = 0; i < COURSES.length; i++) {
    if (COURSES[i].city===city) { course=COURSES[i]; break; }
  }

  if (!course) { noMatch(); return; }
  showResult(course, city, bv, bi);
}

// ── 스팟 HTML ─────────────────────────────────────
function stopHTML(s, isOpt, pal) {
  var ts = TS[s.ty] || TS["activity"];
  var costStr = "";
  if (s.cost && s.cost > 0) {
    costStr = " ~" + (s.cost >= 10000 ? (s.cost/10000).toFixed(s.cost%10000===0?0:1)+"만" : (s.cost/1000)+"천") + "원";
  }
  return '<div class="ti' + (isOpt?" opt-stop":"") + '">'
    + '<div class="tc"><div class="tcr" style="background:' + ts.bg + '">' + s.ic + '</div>'
    + '<div class="tl2">' + s.ti + '</div></div>'
    + '<div class="tf">'
    + '<div class="tty" style="color:' + ts.co + '">' + ts.lb + (isOpt?" ✨":"") + '</div>'
    + '<div class="tn">' + s.n + '</div>'
    + '<div class="td">' + s.d + '</div>'
    + '<div class="tg">'
    + s.tg.map(function(t){return'<span class="tgi">'+t+'</span>';}).join("")
    + (s.st ? '<span class="tst" style="color:'+pal.h+'">★ '+s.st+'</span>' : "")
    + (costStr ? '<span class="tcost">'+costStr+'</span>' : "")
    + "</div></div></div>";
}

// 예산 tier에 따라 스팟 계산
function getStops(course, tier) {
  var stops = course.base_ss.slice();
  for (var i = 0; i < course.opt_ss.length; i++) {
    var os = course.opt_ss[i];
    if (tier >= os.min_tier) stops.push(os.stop);
  }
  stops.sort(function(a,b){
    return parseInt(a.ti.replace(":",""),10) - parseInt(b.ti.replace(":",""),10);
  });
  return stops;
}

// ── 예산 슬라이더 조작 (결과 화면) ───────────────
function onAdjSlide(val) {
  var bi   = parseInt(val, 10);
  var tier = getTier(bi);
  var v    = Math.round(currentBase * ML[Math.min(bi,4)] / 10000);

  document.getElementById("AN").textContent = v;
  document.getElementById("TV").textContent = v + "만원";
  document.getElementById("AT").textContent = ATIPS[Math.min(bi,4)];
  document.getElementById("ANC").textContent = ANOTICE[Math.min(bi,4)];

  var badge = document.getElementById("AB");
  badge.textContent  = MLBL[Math.min(bi,4)];
  badge.style.background  = bi>2?"#fff0f3":bi<2?"#f0fff4":"#fff";
  badge.style.color       = bi>2?"#e06080":bi<2?"#3a8a5a":"#aaa";
  badge.style.borderColor = bi>2?"#fcd5e0":bi<2?"#caffbf":"#f0e6da";

  if (!currentCourse) return;
  var pal       = PAL[currentCourse.city] || PAL["서울"];
  var stops     = getStops(currentCourse, tier);
  var baseNames = currentCourse.base_ss.map(function(s){return s.n;});
  document.getElementById("STOPS").innerHTML = stops.map(function(s){
    return stopHTML(s, baseNames.indexOf(s.n) === -1, pal);
  }).join("");
}

// ── 결과 화면 ─────────────────────────────────────
function showResult(d, city, bv, bi) {
  currentCourse = d;
  currentBase   = d.base;
  var pal  = PAL[city] || PAL["서울"];
  var tier = getTier(bi);
  var iv   = Math.round(currentBase * ML[Math.min(bi,4)] / 10000);

  var stops     = getStops(d, tier);
  var baseNames = d.base_ss.map(function(s){return s.n;});
  var ss = stops.map(function(s){
    return stopHTML(s, baseNames.indexOf(s.n)===-1, pal);
  }).join("");

  var bg = d.bg.map(function(b2){
    return '<div class="brow"><div class="bl">'+b2.l+'</div><div class="bv" style="color:'+pal.h+'">'+b2.a+'</div></div>';
  }).join("");
  var tp = d.tips.map(function(t){
    return '<div class="tr"><span class="tic">'+t.i+'</span><span>'+t.t+'</span></div>';
  }).join("");

  document.getElementById("R").innerHTML =
    '<div class="rh" style="background:'+pal.bg+'">'
    +'<span class="re">'+d.e+'</span>'
    +'<div class="rt">'+d.t+'</div>'
    +'<div class="rs">'+d.s+'</div>'
    +'<div class="rm">'+d.b.map(function(x){return'<span class="rc">'+x+'</span>';}).join('')
    +'<span class="rc">📍 '+city+'</span>'
    +'<span class="rc">💰 '+bv+'만원</span></div></div>'
    +'<div class="rw" style="background:'+pal.bg+'"><svg viewBox="0 0 480 32" preserveAspectRatio="none" fill="#fff9f5"><path d="M0,32 L0,16 Q60,0 120,16 Q180,32 240,16 Q300,0 360,16 Q420,32 480,16 L480,32 Z"/></svg></div>'
    +'<div class="rb">'
    +'<div class="sh"><span class="sn" style="background:'+pal.h+'">01</span>오늘의 코스</div>'
    +'<div class="tl" id="STOPS">'+ss+'</div>'
    +'<div style="margin-top:10px;background:#fff0f5;border-radius:12px;padding:11px 14px;font-size:.78rem;color:#c06080;line-height:1.6;border-left:3px solid #ff8fab">✨ 아래 슬라이더를 조절하면 스팟이 자동으로 추가/삭제돼요!</div>'
    +'<div class="sh"><span class="sn" style="background:'+pal.h+'">02</span>예산 조절</div>'
    +'<div class="bc"><div class="bgr">'+bg+'</div>'
    +'<div class="adj">'
    +'<div class="adj-title">💰 예산 실시간 조절 · 스팟 자동 추가/삭제</div>'
    +'<div class="adj-display">'
    +'<div class="adj-num-wrap"><span class="adj-num" id="AN">'+iv+'</span><span class="adj-unit">만원</span></div>'
    +'<span class="adj-badge" id="AB">기준</span></div>'
    +'<div class="adj-track"><span class="adj-lbl">절약</span>'
    +'<input class="adj-slider" type="range" min="0" max="6" value="'+bi+'" oninput="onAdjSlide(this.value)">'
    +'<span class="adj-lbl">프리미엄</span></div>'
    +'<div class="adj-marks"><span>2만</span><span>3만</span><span>5만</span><span>7만</span><span>10만</span><span>15만</span><span>20만+</span></div>'
    +'<div class="adj-tip" id="AT">'+ATIPS[Math.min(bi,4)]+'</div>'
    +'<div class="adj-notice" id="ANC">'+ANOTICE[Math.min(bi,4)]+'</div></div>'
    +'<div class="btot"><span class="btot-lbl">💳 예상 합계</span><span class="btot-val" id="TV">'+iv+'만원</span></div></div>'
    +'<div class="sh"><span class="sn" style="background:'+pal.h+'">03</span>꿀팁</div>'
    +'<div class="tp">'+tp+'</div>'
    +'<button class="rbtn" onclick="restart()">↺ 다른 코스 찾기</button></div>';

  document.getElementById("R").classList.add("on");
  document.getElementById("Q").classList.remove("on");
  window.scrollTo(0,0);
}

function noMatch() {
  document.getElementById("R").innerHTML =
    '<div style="padding:40px 20px"><div class="nm">'
    +'<div style="font-size:3rem;margin-bottom:12px">🗺️</div>'
    +'<h3 style="font-family:Jua,cursive;font-size:1.3rem;margin-bottom:8px">딱 맞는 코스를 못 찾았어요</h3>'
    +'<p style="font-size:.82rem;color:#aaa;line-height:1.7">다른 조건으로 다시 시도해보세요!</p>'
    +'<button class="rbtn" style="margin-top:18px" onclick="restart()">↺ 다시 찾기</button>'
    +'</div></div>';
  document.getElementById("R").classList.add("on");
  document.getElementById("Q").classList.remove("on");
}

function restart() {
  step=0; currentCourse=null; currentBase=0; ans={}; steps=[];
  document.getElementById("R").classList.remove("on");
  document.getElementById("R").innerHTML = "";
  document.getElementById("Q").classList.add("on");
  render(0);
  window.scrollTo(0,0);
}

render(0);
</script>
</body>
</html>
