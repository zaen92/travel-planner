<link href="https://fonts.googleapis.com/css2?family=Jua&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--bg:#fff9f5;--card:#ffffff;--border:#f0e6da;--mid:#aaa;--p1:#ff8fab;--p2:#ffc8dd;--p3:#bde0fe;--p4:#a2d2ff;--p5:#caffbf;--dark:#3d3035}
body{background:var(--bg);font-family:'Noto Sans KR',sans-serif;color:var(--dark);max-width:480px;margin:0 auto;min-height:100dvh;overflow-x:hidden}
.scr{display:none}.scr.on{display:block}
.hero{background:linear-gradient(135deg,#ffb3c6 0%,#ffc8dd 40%,#bde0fe 75%,#a2d2ff 100%);padding:52px 24px 40px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-30px;right:-30px;width:160px;height:160px;background:rgba(255,255,255,.22);border-radius:50%}
.hero::after{content:'';position:absolute;bottom:-40px;left:-20px;width:120px;height:120px;background:rgba(255,255,255,.18);border-radius:50%}
.hbg{display:inline-flex;background:#fff;color:var(--p1);font-family:'Jua',cursive;font-size:.75rem;letter-spacing:.5px;padding:5px 14px;border-radius:99px;margin-bottom:16px;position:relative;z-index:1;box-shadow:0 2px 8px rgba(255,143,171,.3)}
.hero h1{font-family:'Jua',cursive;font-size:2.4rem;color:#fff;line-height:1.2;position:relative;z-index:1;letter-spacing:-1px;text-shadow:0 2px 12px rgba(255,107,143,.2)}
.hero h1 em{font-style:normal;color:rgba(255,255,255,.95)}
.hero p{color:rgba(255,255,255,.85);font-size:.84rem;margin-top:10px;position:relative;z-index:1}
.wv{width:100%;overflow:hidden;line-height:0;background:linear-gradient(135deg,#ffc8dd,#bde0fe)}
.wv svg{display:block;width:100%;height:36px}
.sw{padding:28px 20px 100px}
.dots{display:flex;gap:8px;margin-bottom:26px;justify-content:center}
.dot{width:8px;height:8px;border-radius:50%;background:#f0d5e0;transition:all .3s}
.dot.on{width:28px;border-radius:4px;background:linear-gradient(90deg,var(--p1),var(--p4))}
.dot.dn{background:var(--p5)}
.qb{background:var(--card);border-radius:24px;padding:24px 20px;box-shadow:0 2px 0 #f7dce8,4px 6px 0 #f7dce8;border:1.5px solid #fce4ec;animation:pop .35s cubic-bezier(.34,1.56,.64,1)}
