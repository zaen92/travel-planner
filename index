.qchip{display:inline-block;font-size:.66rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:4px 12px;border-radius:99px;margin-bottom:12px}
.qb h2{font-family:'Jua',cursive;font-size:1.3rem;line-height:1.4;margin-bottom:18px}
/* 2열 그리드 옵션 */
.olist{display:flex;flex-direction:column;gap:10px}
.olist.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.ob{background:#fff9fb;border:2px solid #fce4ec;border-radius:16px;padding:13px 14px;cursor:pointer;display:flex;align-items:center;gap:10px;font-family:'Noto Sans KR',sans-serif;font-size:.86rem;font-weight:500;color:var(--dark);text-align:left;-webkit-appearance:none;width:100%;transition:all .18s}
.ob:active{transform:scale(.97)}
.oi{font-size:1.4rem;flex-shrink:0}
.ot{flex:1;line-height:1.3;min-width:0}
.os{font-size:.68rem;color:var(--mid);display:block;margin-top:2px;font-weight:400}
.oc{width:20px;height:20px;border-radius:50%;border:2px solid #f0d5e0;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.68rem;color:#fff;transition:all .18s}
/* 슬라이더 */
.sb{margin-top:4px}
.sd{text-align:center;margin-bottom:22px}
.sv{font-family:'Jua',cursive;font-size:4rem;line-height:1;background:linear-gradient(135deg,var(--p1),var(--p4));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.su{font-size:.8rem;color:var(--mid);margin-top:6px}
.st{display:flex;align-items:center;gap:12px}
.sl{font-size:.7rem;color:var(--mid);font-weight:600;white-space:nowrap}
input[type=range]{-webkit-appearance:none;appearance:none;flex:1;height:8px;background:linear-gradient(90deg,var(--p1),var(--p3));border-radius:99px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:28px;height:28px;border-radius:50%;background:#fff;border:3px solid var(--p1);cursor:pointer;box-shadow:0 2px 10px rgba(255,143,171,.4);transition:transform .15s}
input[type=range]::-webkit-slider-thumb:active{transform:scale(1.2)}
.sm{display:flex;justify-content:space-between;margin-top:8px}
.sm span{font-size:.62rem;color:var(--mid)}
.nb{width:100%;margin-top:18px;background:linear-gradient(135deg,var(--p1),#ff6b9d 50%,var(--p4) 100%);color:#fff;border:none;border-radius:16px;padding:17px;font-family:'Jua',cursive;font-size:1.1rem;cursor:pointer;-webkit-appearance:none;box-shadow:0 4px 16px rgba(255,143,171,.45);transition:all .2s}
