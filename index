.tp{background:linear-gradient(135deg,#f0fff4,#e8f4ff);border-radius:18px;padding:20px;border:1.5px solid #caf0d0;box-shadow:3px 4px 0 #d8f0dc;margin-bottom:12px}
.tr{display:flex;gap:12px;padding:9px 0;border-bottom:1px dashed #cde8d0;font-size:.83rem;color:#555;line-height:1.6}
.tr:last-child{border-bottom:none;padding-bottom:0}
.tic{flex-shrink:0}
.rbtn{width:100%;background:#fff;border:2px solid #fcd5e0;border-radius:14px;padding:15px;font-family:'Jua',cursive;font-size:1rem;color:var(--p1);cursor:pointer;box-shadow:3px 4px 0 #fcd5e0;transition:all .18s;margin-top:4px}
.rbtn:active{transform:translate(2px,3px);box-shadow:none}
.nm{background:var(--card);border-radius:18px;padding:32px 24px;text-align:center;border:1.5px solid var(--border);box-shadow:3px 4px 0 #f0e0e8}
</style>
</head>
