.adj-num-wrap{display:flex;align-items:baseline;gap:3px;flex:1}
.adj-num{font-family:'Jua',cursive;font-size:2.8rem;line-height:1;background:linear-gradient(135deg,var(--p1),var(--p4));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.adj-unit{font-size:.85rem;color:var(--mid)}
.adj-badge{font-size:.72rem;font-weight:700;padding:4px 12px;border-radius:99px;background:#fff;border:1.5px solid var(--border);color:var(--mid);transition:all .25s}
.adj-track{display:flex;align-items:center;gap:10px}
.adj-lbl{font-size:.7rem;color:var(--mid);white-space:nowrap;font-weight:600}
