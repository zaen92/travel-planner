.ti.opt-stop{border-style:dashed;border-color:var(--p2);background:#fffcfd}
.ti.opt-stop::before{content:'✨';font-size:.75rem;position:absolute;right:12px;top:12px}
.ti{position:relative}
@keyframes slr{from{opacity:0;transform:translateX(-14px)}to{opacity:1;transform:translateX(0)}}
.tc{display:flex;flex-direction:column;align-items:center;gap:5px;flex-shrink:0;padding-top:2px}
.tcr{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.tl2{font-size:.6rem;font-weight:700;color:var(--mid);white-space:nowrap}
.tf{flex:1;min-width:0}
.tty{font-size:.62rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:5px}
